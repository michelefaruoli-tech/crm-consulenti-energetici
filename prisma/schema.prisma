generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SEGRETERIA
  COLLABORATORE
  COMMERCIALE
}

enum ContractStatus {
  BOZZA
  INSERITO
  DOCUMENTAZIONE_INCOMPLETA
  DOCUMENTAZIONE_COMPLETA
  INVIATO_AL_FORNITORE
  IN_LAVORAZIONE
  ATTIVATO
  IN_ATTESA_PAGAMENTO
  PAGATO_DAL_FORNITORE
  PROVVIGIONE_LIQUIDATA
  CHIUSO
  ANNULLATO
}

enum CommissionPaymentType {
  MENSILE
  UNA_TANTUM
  RATEIZZATO
  BONUS
  PREMIO
}

enum ClientType {
  PRIVATO
  AZIENDA
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(COLLABORATORE)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientsCreated   Client[]                @relation("ClientCreatedBy")
  contracts        Contract[]              @relation("ContractCollaborator")
  statusChanges    ContractStatusHistory[]
  auditLogs        AuditLog[]
  commissionPayouts CommissionEntry[]      @relation("CommissionPaidBy")
}

model Client {
  id          String     @id @default(cuid())
  type        ClientType @default(PRIVATO)
  companyName String?
  firstName   String?
  lastName    String?
  fiscalCode  String?
  vatNumber   String?
  email       String?
  pec         String?
  phone       String?
  iban        String?
  address     String?
  city        String?
  province    String?
  region      String?
  zipCode     String?
  /// Residente / Non residente / Altri usi
  classification String?
  supplyAddress  String?
  supplyCity     String?
  supplyProvince String?
  supplyRegion   String?
  supplyZipCode  String?
  addressesMatch Boolean?
  notes       String?
  createdById String
  createdBy   User       @relation("ClientCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  contracts Contract[]
  documents Document[]
  history   ClientHistory[]

  @@index([fiscalCode])
  @@index([vatNumber])
  @@index([lastName, firstName])
  @@index([email])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  active    Boolean  @default(true)
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services        Service[]
  commissionRules CommissionRule[]
  contracts       Contract[]
}

model Service {
  id         String   @id @default(cuid())
  name       String
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  contracts       Contract[]
  commissionRules CommissionRule[]
}

model CommissionRule {
  id           String                @id @default(cuid())
  supplierId   String
  supplier     Supplier              @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  serviceId    String?
  service      Service?              @relation(fields: [serviceId], references: [id])
  name         String
  paymentType  CommissionPaymentType @default(UNA_TANTUM)
  fixedAmount  Decimal?              @db.Decimal(10, 2)
  percentage   Decimal?              @db.Decimal(5, 2)
  installments Int?
  validFrom    DateTime              @default(now())
  validTo      DateTime?
  active       Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  contracts Contract[]
}

model Contract {
  id               String         @id @default(cuid())
  /// ID originale dal foglio Excel / sistema precedente
  externalId       String?        @unique
  contractNumber   String         @unique
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id])
  collaboratorId   String
  collaborator     User           @relation("ContractCollaborator", fields: [collaboratorId], references: [id])
  supplierId       String
  supplier         Supplier       @relation(fields: [supplierId], references: [id])
  serviceId        String?
  service          Service?       @relation(fields: [serviceId], references: [id])
  commissionRuleId String?
  commissionRule   CommissionRule? @relation(fields: [commissionRuleId], references: [id])
  status           ContractStatus @default(BOZZA)

  /// Luce / Gas / Telefonia / Fibra...
  utilityType      String?
  productName      String?
  /// POD o PDR
  podPdr           String?
  /// Fisso / Variabile
  priceType        String?
  pcv              Decimal?       @db.Decimal(10, 4)
  pricePerKwh      Decimal?       @db.Decimal(10, 6)
  bandCount        Int?
  bandsJson        String?
  /// Una tantum / Mensile...
  recurrence       String?
  paymentMethod    String?
  operationType    String?
  agency           String?
  rowType          String?
  parentExternalId String?
  monthlyPeriod    String?

  insertionDate    DateTime       @default(now())
  receivedDate     DateTime?
  /// Data inizio fornitura (calcolata: regola giorno 8 / +7gg voltura-attivazione)
  supplyStartDate  DateTime?
  activationDate   DateTime?
  paymentDate      DateTime?
  collectionDate   DateTime?
  expiryDate       DateTime?
  stornoEndDate    DateTime?
  workEmailDate    DateTime?

  paymentStatus    String?
  workStatus       String?
  toWork           Boolean        @default(false)
  manuallyVerified Boolean        @default(false)
  /// Contratti già chiusi/pagati importati solo per storico e report
  isHistorical     Boolean        @default(false)
  /// Etichetta lotto storico (es. "Excel pagati 2024")
  archiveLabel     String?
  /// false = giallo (proposta collab), true = verde (confermata admin)
  commissionConfirmed Boolean     @default(false)
  commissionConfirmedAt DateTime?
  attachmentsJson  String?
  notes            String?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  statusHistory ContractStatusHistory[]
  documents     Document[]
  commission    Commission?
  recurringMonths RecurringMonth[]

  @@index([status])
  @@index([collaboratorId])
  @@index([supplierId])
  @@index([podPdr])
  @@index([insertionDate])
  @@index([expiryDate])
  @@index([commissionConfirmed])
  @@index([isHistorical])
  @@index([archiveLabel])
}

model ContractStatusHistory {
  id          String          @id @default(cuid())
  contractId  String
  contract    Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  fromStatus  ContractStatus?
  toStatus    ContractStatus
  changedById String
  changedBy   User            @relation(fields: [changedById], references: [id])
  changedAt   DateTime        @default(now())
  note        String?
}

model Commission {
  id         String   @id @default(cuid())
  contractId String   @unique
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  expected   Decimal  @default(0) @db.Decimal(10, 2)
  accrued    Decimal  @default(0) @db.Decimal(10, 2)
  received   Decimal  @default(0) @db.Decimal(10, 2)
  paid       Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entries CommissionEntry[]
}

/// Tracciamento mensile per contratti ricorrenti (es. Helios)
model RecurringMonth {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  /// YYYY-MM
  period     String
  /// PAID | PENDING | MISSING | CLOSED | ERROR_UNPAID
  status     String   @default("PENDING")
  amount     Decimal? @db.Decimal(10, 2)
  paidAt     DateTime?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([contractId, period])
  @@index([status])
  @@index([period])
  @@index([contractId])
}

model CommissionEntry {
  id           String     @id @default(cuid())
  commissionId String
  commission   Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  type         String
  amount       Decimal    @db.Decimal(10, 2)
  note         String?
  paidById     String?
  paidBy       User?      @relation("CommissionPaidBy", fields: [paidById], references: [id])
  createdAt    DateTime   @default(now())
}

model Document {
  id         String    @id @default(cuid())
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: Cascade)
  filename   String
  mimeType   String
  size       Int
  path       String
  uploadedAt DateTime  @default(now())
}

model ClientHistory {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  field     String
  oldValue  String?
  newValue  String?
  changedBy String
  changedAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
}

model BackupLog {
  id        String   @id @default(cuid())
  filename  String
  size      Int?
  status    String
  createdAt DateTime @default(now())
}
