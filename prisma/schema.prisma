generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SEGRETERIA
  COLLABORATORE
  COMMERCIALE
}

enum ContractStatus {
  BOZZA
  INSERITO
  DOCUMENTAZIONE_INCOMPLETA
  DOCUMENTAZIONE_COMPLETA
  INVIATO_AL_FORNITORE
  DA_LAVORARE
  INVIATO_AL_MASTER
  ERRORE_INVIO
  IN_LAVORAZIONE
  ATTIVATO
  IN_ATTESA_PAGAMENTO
  PAGATO_DAL_FORNITORE
  PROVVIGIONE_LIQUIDATA
  COMPLETATO
  CHIUSO
  ANNULLATO
  /// Pratica Master non andata a buon fine
  KO
}

enum CommissionPaymentType {
  MENSILE
  UNA_TANTUM
  RATEIZZATO
  BONUS
  PREMIO
}

enum ClientType {
  PRIVATO
  AZIENDA
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(COLLABORATORE)
  active    Boolean  @default(true)
  passwordChangedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientsCreated   Client[]                @relation("ClientCreatedBy")
  contracts        Contract[]              @relation("ContractCollaborator")
  contractsCreated Contract[]              @relation("ContractCreatedBy")
  statusChanges    ContractStatusHistory[]
  auditLogs        AuditLog[]
  commissionPayouts CommissionEntry[]      @relation("CommissionPaidBy")
  emailLogsSent    ContractEmailLog[]      @relation("EmailSentBy")
  passwordResetTokens PasswordResetToken[]
  securityEvents   UserSecurityEvent[]
}

model Client {
  id          String     @id @default(cuid())
  type        ClientType @default(PRIVATO)
  companyName String?
  firstName   String?
  lastName    String?
  fiscalCode  String?
  vatNumber   String?
  email       String?
  pec         String?
  phone       String?
  iban        String?
  address     String?
  street      String?
  streetNumber String?
  city        String?
  province    String?
  region      String?
  zipCode     String?
  country     String?    @default("Italia")
  /// Residente / Non residente / Altri usi
  classification String?
  /// Business: rappresentante legale
  legalFirstName String?
  legalLastName  String?
  legalFiscalCode String?
  sdiCode        String?
  supplyAddress  String?
  supplyStreet   String?
  supplyStreetNumber String?
  supplyCity     String?
  supplyProvince String?
  supplyRegion   String?
  supplyZipCode  String?
  addressesMatch Boolean?
  notes       String?
  deletedAt   DateTime?
  createdById String
  createdBy   User       @relation("ClientCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  contracts Contract[]
  documents Document[]
  history   ClientHistory[]

  @@index([fiscalCode])
  @@index([vatNumber])
  @@index([lastName, firstName])
  @@index([email])
  @@index([deletedAt])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  active    Boolean  @default(true)
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services        Service[]
  commissionRules CommissionRule[]
  contracts       Contract[]
}

model Service {
  id         String   @id @default(cuid())
  name       String
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  contracts       Contract[]
  commissionRules CommissionRule[]
}

model CommissionRule {
  id           String                @id @default(cuid())
  supplierId   String
  supplier     Supplier              @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  serviceId    String?
  service      Service?              @relation(fields: [serviceId], references: [id])
  name         String
  paymentType  CommissionPaymentType @default(UNA_TANTUM)
  fixedAmount  Decimal?              @db.Decimal(10, 2)
  percentage   Decimal?              @db.Decimal(5, 2)
  installments Int?
  validFrom    DateTime              @default(now())
  validTo      DateTime?
  active       Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  contracts Contract[]
}

model Contract {
  id               String         @id @default(cuid())
  /// ID originale dal foglio Excel / sistema precedente
  externalId       String?        @unique
  contractNumber   String         @unique
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id])
  collaboratorId   String
  collaborator     User           @relation("ContractCollaborator", fields: [collaboratorId], references: [id])
  createdById      String?
  createdBy        User?          @relation("ContractCreatedBy", fields: [createdById], references: [id])
  supplierId       String
  supplier         Supplier       @relation(fields: [supplierId], references: [id])
  serviceId        String?
  service          Service?       @relation(fields: [serviceId], references: [id])
  commissionRuleId String?
  commissionRule   CommissionRule? @relation(fields: [commissionRuleId], references: [id])
  status           ContractStatus @default(BOZZA)

  /// Luce / Gas / Telefonia / POS / Fotovoltaico...
  utilityType      String?
  productName      String?
  offerCode        String?
  contractKind     String?
  /// POD o PDR (legacy singolo)
  podPdr           String?
  pod              String?
  pdr              String?
  /// Fisso / Variabile / Indicizzato
  priceType        String?
  pcv              Decimal?       @db.Decimal(10, 4)
  pricePerKwh      Decimal?       @db.Decimal(10, 6)
  pricePerSmc      Decimal?       @db.Decimal(10, 6)
  spread           Decimal?       @db.Decimal(10, 6)
  monthlyFee       Decimal?       @db.Decimal(10, 2)
  oneOffFee        Decimal?       @db.Decimal(10, 2)
  discount         Decimal?       @db.Decimal(10, 2)
  powerKw          Decimal?       @db.Decimal(10, 2)
  annualKwh        Decimal?       @db.Decimal(12, 2)
  annualSmc        Decimal?       @db.Decimal(12, 2)
  bandCount        Int?
  bandsJson        String?
  economicNotes    String?
  /// Una tantum / Mensile...
  recurrence       String?
  paymentMethod    String?
  ibanHolder       String?
  ibanHolderCf     String?
  invoiceEmail     String?
  invoiceMode      String?
  billingPeriod    String?
  operationType    String?
  operationOther   String?
  serviceOther     String?
  agency           String?
  rowType          String?
  parentExternalId String?
  parentContractId String?
  monthlyPeriod    String?
  supplyClassification String?
  durationMonths   Int            @default(12)
  sendToMaster     Boolean        @default(false)
  assignedToMaster Boolean        @default(false)
  sentToMasterAt   DateTime?
  masterEmail      String?
  emailStatus      String?
  emailMessageId   String?
  emailAttempts    Int            @default(0)
  emailLastError   String?
  emailIdempotencyKey String?
  koReason         String?
  koNotes          String?
  workCompletedAt  DateTime?
  expectedPaymentAmount Decimal?  @db.Decimal(10, 2)
  expectedPaymentDate DateTime?
  paymentAmount    Decimal?       @db.Decimal(10, 2)
  masterNotes      String?
  internalNotes    String?
  workNotes        String?
  /// JSON condizioni/servizi tecnici extra
  technicalJson    String?
  economicJson     String?
  paymentJson      String?

  insertionDate    DateTime       @default(now())
  subscriptionDate DateTime?
  receivedDate     DateTime?
  /// Data inizio fornitura
  supplyStartDate  DateTime?
  activationDate   DateTime?
  paymentDate      DateTime?
  collectionDate   DateTime?
  expiryDate       DateTime?
  stornoEndDate    DateTime?
  workEmailDate    DateTime?

  paymentStatus    String?
  workStatus       String?
  toWork           Boolean        @default(false)
  manuallyVerified Boolean        @default(false)
  isHistorical     Boolean        @default(false)
  archiveLabel     String?
  commissionConfirmed Boolean     @default(false)
  commissionConfirmedAt DateTime?
  attachmentsJson  String?
  notes            String?
  deletedAt        DateTime?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  statusHistory ContractStatusHistory[]
  documents     Document[]
  commission    Commission?
  recurringMonths RecurringMonth[]
  emailLogs     ContractEmailLog[]

  @@index([status])
  @@index([collaboratorId])
  @@index([supplierId])
  @@index([podPdr])
  @@index([pod])
  @@index([pdr])
  @@index([insertionDate])
  @@index([expiryDate])
  @@index([commissionConfirmed])
  @@index([isHistorical])
  @@index([archiveLabel])
  @@index([deletedAt])
  @@index([sendToMaster])
  @@index([assignedToMaster])
  @@index([sentToMasterAt])
}

model ContractStatusHistory {
  id          String          @id @default(cuid())
  contractId  String
  contract    Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  fromStatus  ContractStatus?
  toStatus    ContractStatus
  changedById String
  changedBy   User            @relation(fields: [changedById], references: [id])
  changedAt   DateTime        @default(now())
  note        String?
  changeReason String?
  koReason     String?
  expectedPaymentAmount Decimal? @db.Decimal(10, 2)
  expectedPaymentDate   DateTime?
  activationDate        DateTime?
  paymentDate           DateTime?
  paymentAmount         Decimal? @db.Decimal(10, 2)
}

model Commission {
  id         String   @id @default(cuid())
  contractId String   @unique
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  expected   Decimal  @default(0) @db.Decimal(10, 2)
  accrued    Decimal  @default(0) @db.Decimal(10, 2)
  received   Decimal  @default(0) @db.Decimal(10, 2)
  paid       Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entries CommissionEntry[]
}

/// Tracciamento mensile per contratti ricorrenti (es. Helios)
model RecurringMonth {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  /// YYYY-MM
  period     String
  /// PAID | PENDING | MISSING | CLOSED | ERROR_UNPAID
  status     String   @default("PENDING")
  amount     Decimal? @db.Decimal(10, 2)
  paidAt     DateTime?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([contractId, period])
  @@index([status])
  @@index([period])
  @@index([contractId])
}

model CommissionEntry {
  id           String     @id @default(cuid())
  commissionId String
  commission   Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  type         String
  amount       Decimal    @db.Decimal(10, 2)
  note         String?
  paidById     String?
  paidBy       User?      @relation("CommissionPaidBy", fields: [paidById], references: [id])
  createdAt    DateTime   @default(now())
}

model Document {
  id         String    @id @default(cuid())
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: Cascade)
  filename   String
  mimeType   String
  size       Int
  path       String
  /// Tipologia documento (CI_FRONTE, BOLLETTA, ...)
  docType    String?
  /// Contenuto base64 per allegati piccoli / email (Vercel FS effimero)
  contentBase64 String?
  uploadedAt DateTime  @default(now())
}

model ContractEmailLog {
  id           String   @id @default(cuid())
  contractId   String
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  toEmail      String
  subject      String
  status       String
  /// MASTER_NEW | MASTER_RESEND | DAILY_REPORT | PASSWORD_RESET | OTHER
  emailType    String   @default("MASTER_NEW")
  error        String?
  attempts     Int      @default(1)
  messageId    String?
  sentById     String?
  sentBy       User?    @relation("EmailSentBy", fields: [sentById], references: [id])
  /// Idempotency / payload hash
  payloadHash  String?
  sentAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([contractId])
  @@index([payloadHash])
  @@index([status])
  @@index([emailType])
}

model DailyContractReport {
  id             String   @id @default(cuid())
  /// YYYY-MM-DD Europe/Rome
  reportDate     String
  recipient      String
  contractsCount Int      @default(0)
  status         String
  messageId      String?
  attempts       Int      @default(1)
  lastError      String?
  payloadSummary String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([reportDate, recipient])
  @@index([reportDate])
  @@index([status])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Hash del token (mai token in chiaro)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model UserSecurityEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// PASSWORD_CHANGED | PASSWORD_RESET_REQUESTED | PASSWORD_RESET_COMPLETED | LOGIN
  eventType String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([eventType])
}

model ClientHistory {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  field     String
  oldValue  String?
  newValue  String?
  changedBy String
  changedAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
}

model ContractNumberSequence {
  /// Anno (es. 2026)
  year Int @id
  last Int @default(0)
}

model CreateIdempotency {
  key         String   @id
  contractIds String
  userId      String?
  createdAt   DateTime @default(now())
}

model BackupLog {
  id        String   @id @default(cuid())
  filename  String
  size      Int?
  status    String
  createdAt DateTime @default(now())
}
